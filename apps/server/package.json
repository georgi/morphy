{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter @chess/shared build && nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest && jest --config ./test/jest-e2e.json",
    "test:unit": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@chess/shared$": "<rootDir>/../../../packages/shared/src/index.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@chess/shared": "workspace:*",
    "@earendil-works/pi-coding-agent": "^0.78",
    "@nestjs/common": "^11.1",
    "@nestjs/core": "^11.1",
    "@nestjs/platform-express": "^11.1",
    "@sinclair/typebox": "^0.34",
    "better-sqlite3": "^12.10.0",
    "chess.js": "^1.4",
    "node-uci": "^1.3",
    "reflect-metadata": "^0.2",
    "rxjs": "^7.8",
    "uuid": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/supertest": "^6",
    "@types/uuid": "^10",
    "jest": "^29",
    "supertest": "^7",
    "ts-jest": "^29",
    "typescript": "^5.7.2"
  }
}
